# === API Keys ===
BRAVE_API_KEY=your_brave_search_api_key_here
CONTEXT7_API_KEY=your_context7_api_key_here

# === PROXIES (geo-split external proxies for global aggregation) ===
# Format: http://user:pass@ip:port
PROXY1_US=http://proxy-us:port
PROXY2_EU=http://proxy-eu:port
PROXY3_ASIA=http://proxy-asia:port
# Add more as needed — edit squid.conf to include them all

# === GITEA (now external — use your main host IP or domain) ===
GITEA_EXTERNAL_URL=http://YOUR-MAIN-AI-HOST-IP:3002   # e.g. http://192.168.1.50:3002
GITEA_TOKEN=your_gitea_personal_access_token
GITEA_USERNAME=admin

# === MCP Ports (exposed on this host's IP) ===
FILESYSTEM_PORT=8011
PLAYWRIGHT_PORT=8012
CONTEXT7_PORT=8013
GITEA_MCP_PORT=8014
BRAVE_MCP_PORT=8015

# === Workspace (mount your code/repos here on the MCP host) ===
WORKSPACE_HOST_PATH=/path/to/your/homelab/code/on/this/host
