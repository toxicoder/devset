{
  "name": "Ultimate Dev Container (Ubuntu 24.04 Multi-Arch)",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false,
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/node:1": { "version": "lts" },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" },
    "ghcr.io/devcontainers-community/features/bazel:1": {
      "bazelisk_version": "latest",
      "buildifier_version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode-remote.remote-containers",
        "bierner.markdown-mermaid",
        "bazelbuild.vscode-bazel"
      ]
    }
  },
  "remoteUser": "vscode",
  "runArgs": ["--env-file", ".env"],
  "postCreateCommand": "echo '✅ Ultimate dev environment ready! Run node --version, python --version, docker --version, bazel --version to verify.'",
  "hostRequirements": {
    "cpus": 2,
    "memory": "4gb",
    "storage": "10gb",
    "gpu": "optional"
  }
}
