# .bazelrc - Bazel Build Configuration
#
# This file specifies command-line options to use by default.
# Reference: https://bazel.build/run/bazelrc

# =============================================================================
# Build Mode Defaults
# =============================================================================

# Use optimized build by default
build --compilation_mode=opt

# Enable support for starlark based language analysis in the IDE
build --features=mixed_mode

# =============================================================================
# Test Configuration
# =============================================================================

# Run tests in verbose mode by default
test --test_detail=all

# Enable coverage collection
test --coverage
