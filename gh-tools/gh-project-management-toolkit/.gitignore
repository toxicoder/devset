# =============================================================================
# .gitignore for gh-project-management-toolkit
#
# This file specifies intentionally untracked files that Git should ignore.
# =============================================================================

# =============================================================================
# Generated Protocol Buffer Files (NEVER COMMIT)
# =============================================================================
# These files are generated by Bazel during build and must never be committed.
# They are regenerated automatically from .proto files.
**/*_pb2.py
**/*_pb2_grpc.py

# =============================================================================
# Python Artifacts
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
*.egg

# =============================================================================
# IDE and Editor Files
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Test and Coverage Artifacts
# =============================================================================
.coverage
htmlcov/
.tox/
.nox/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# =============================================================================
# Virtual Environments (should use Bazel instead)
# =============================================================================
venv/
.env/
.venv/

# =============================================================================
# Logs and Temporary Files
# =============================================================================
*.log
*.tmp
temp/